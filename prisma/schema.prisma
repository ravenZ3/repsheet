generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  dailyReviewLimit Int       @default(20)
  leetcodeUsername String?
  leetcodeLastSyncDate DateTime?
  codeforcesHandle String?
  codeforcesLastSyncId Int?
  fsrsTargetRetention Float @default(0.90)
  showPatterns     Boolean @default(false)
  focusTags        String[] @default([])
  activeFocus      String?
  accounts         Account[]
  sessions         Session[]
  problems         Problem[]
  reviews          Review[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Difficulty {
  Easy
  Medium
  Hard
}


model Problem {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @db.ObjectId
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId      String?   @db.ObjectId
  name           String
  platform       String?
  problemCode    String?
  link           String?
  difficulty     Difficulty
  isStuck        Boolean   @default(false)
  isStarred      Boolean   @default(false)
  category       String[]
  notes          String?
  mistakesMade   String?
  dateSolved     DateTime?
  // Non-nullable: capture/mark use `where: { reviewCount: <read value> }` as an
  // optimistic lock, and Prisma+Mongo `field: null` filters match no rows — a
  // null here would silently drop the row's first rating.
  reviewCount    Int       @default(0)
  nextReviewDate DateTime?
  stability      Float?
  fsrsDifficulty Float?
  fsrsState      Int       @default(0)
  lastRating     Int?
  lastReview     DateTime?
  platformRating Int?
  reviews        Review[]
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  problemId String   @db.ObjectId
  date      DateTime @default(now())
  rating    Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}
