{
  "manifest_version": 3,
  "name": "Repsheet — Capture & Review",
  "version": "0.1.0",
  "description": "Capture and FSRS-rate competitive programming problems the moment you solve them, plus review reminders.",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://repsheet.vercel.app/*"
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Repsheet",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://codeforces.com/contest/*",
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/gym/*"
      ],
      "js": [
        "src/browser-shim.js",
        "src/config.js",
        "src/adapters/leetcode.js",
        "src/adapters/codeforces.js",
        "src/overlay.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "repsheet@repsheet.app",
      "strict_min_version": "115.0"
    }
  }
}
